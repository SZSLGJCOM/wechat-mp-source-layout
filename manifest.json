{
  "manifest_version": 3,
  "name": "公众号源码排版助手",
  "short_name": "源码排版",
  "description": "微信公众号图文编辑页 Chrome 扩展，支持 HTML 源码编辑、图片参数微调、多图 SVG 动效与成品复原管理。",
  "version": "1.0.0",
  "version_name": "1.0.0",
  "permissions": [],
  "host_permissions": [
    "https://mp.weixin.qq.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://mp.weixin.qq.com/*"
      ],
      "js": [
        "src/bridge-client.js",
        "src/content.js",
        "src/image-geometry.js",
        "src/image-controls.js",
        "src/image-snapshot-merge.js",
        "src/image-tools.js",
        "src/svg-tools.js",
        "src/svg-block-tools.js"
      ],
      "css": [
        "src/overlay.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/page-bridge.js"
      ],
      "matches": [
        "https://mp.weixin.qq.com/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
